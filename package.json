{
  "name": "ai-office-agent-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "pb:migrate": "./pocketbase migrate up",
    "pb:serve": "./pocketbase serve",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "node --test \"test/**/*.test.js\"",
    "preview": "vite preview",
    "start": "node server/index.js",
    "verify:ai": "node scripts/verify-ai-e2e.mjs",
    "verify:memory": "node scripts/verify-memory-save.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^1.14.0",
    "pocketbase": "^0.26.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "undici": "^7.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
