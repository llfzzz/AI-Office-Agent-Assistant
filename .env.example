PORT=8788
PB_URL=http://127.0.0.1:8090
JSON_BODY_LIMIT=10mb

# Secret used to encrypt per-user AI provider API keys at rest (AES-256-GCM).
# Must be >= 16 chars. Generate one with: openssl rand -base64 32
# Without it, saved custom keys are disabled and AI calls fall back to demo mode.
# Rotating this value makes previously stored keys undecryptable (re-save them).
AI_CONFIG_SECRET=
# Timeout (ms) for the "validate" test call against a provider.
AI_VALIDATE_TIMEOUT_MS=15000

# Optional: HTTPS proxy used only for outbound AI provider requests.
#AI_HTTPS_PROXY=http://127.0.0.1:7890
# Optional tuning (defaults in parentheses): AI_TIMEOUT_MS (90000),
# AI_RETRY_ATTEMPTS (4), AI_MAX_OUTPUT_TOKENS (2000), AI_THINKING_LEVEL (low),
# AI_AUDIO_TIMEOUT_MS (120000), AI_AUDIO_CONVERT_TIMEOUT_MS (60000),
# AI_EXTRACT_TIMEOUT_MS (120000), AI_UPLOAD_TIMEOUT_MS (120000),
# MEETING_FILE_MAX_CHARS (24000), APP_BASE_PATH (/office-agent).
