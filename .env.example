PORT=8788
PB_URL=http://127.0.0.1:8090
JSON_BODY_LIMIT=10mb

# Secret used to encrypt per-user AI provider API keys at rest (AES-256-GCM).
# Must be >= 16 chars. Generate one with: openssl rand -base64 32
# Without it, saved custom keys are disabled (default/env Gemini still works).
# Rotating this value makes previously stored keys undecryptable (re-save them).
AI_CONFIG_SECRET=
# Timeout (ms) for the "validate" test call against a provider.
AI_VALIDATE_TIMEOUT_MS=15000

GEMINI_API_KEY=
GEMINI_HTTPS_PROXY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_UPLOAD_BASE_URL=https://generativelanguage.googleapis.com/upload/v1beta
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MAX_OUTPUT_TOKENS=2000
GEMINI_THINKING_LEVEL=low
GEMINI_TIMEOUT_MS=90000
GEMINI_RETRY_ATTEMPTS=4
GEMINI_AUDIO_TIMEOUT_MS=120000
GEMINI_AUDIO_CONVERT_TIMEOUT_MS=60000
GEMINI_EXTRACT_TIMEOUT_MS=120000
